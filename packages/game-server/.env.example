# Must match packages/website GAME_SERVER_API_KEY (HMAC for game WebSocket tokens)
GAME_SERVER_API_KEY=

# Optional stable id for distributed single-session leases (defaults to hostname:port:pid)
# GAME_SERVER_INSTANCE_ID=my-shard-1

# POST /__dev/reload-world-map (map editor → game server). Set to false to disable.
# ENABLE_EDITOR_MAP_RELOAD=false
#
# In NODE_ENV=production, this endpoint only accepts TCP connections from loopback
# (127.0.0.0/8, ::1). EDITOR_MAP_RELOAD_ALLOW_NON_LOCAL is ignored in production.
# Non-production only (e.g. Docker): allow non-loopback peers if you must:
# EDITOR_MAP_RELOAD_ALLOW_NON_LOCAL=true
