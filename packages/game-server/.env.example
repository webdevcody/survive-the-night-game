# Must match packages/website GAME_SERVER_API_KEY (HMAC for game WebSocket tokens)
GAME_SERVER_API_KEY=

# Optional stable id for distributed single-session leases (defaults to hostname:port:pid)
# GAME_SERVER_INSTANCE_ID=my-shard-1

# Stable numeric id (e.g. 100): used for session leases and boot-time lease cleanup. When set with
# GAME_SERVER_API_KEY, clears all users' active_game_server_id matching this id before listen.
# GAME_SERVER_ID=100

# Public WebSocket URL browsers use (required when registering in DB).
# GAME_SERVER_PUBLIC_WS_URL=ws://127.0.0.1:3001

# Optional display name in the server picker.
# GAME_SERVER_DISPLAY_NAME=Local dev

# Optional region label stored with the world in the website DB (game_server.region).
# GAME_SERVER_REGION=us-east

# Website base URL for server-to-server API (session, registry). Start the website on this URL
# before the game server, or register/clear will fail with ECONNREFUSED.
# WEBSITE_API_URL=http://localhost:3000

# POST /__dev/reload-world-map (map editor → game server). Set to false to disable.
# ENABLE_EDITOR_MAP_RELOAD=false
#
# In NODE_ENV=production, this endpoint only accepts TCP connections from loopback
# (127.0.0.0/8, ::1). EDITOR_MAP_RELOAD_ALLOW_NON_LOCAL is ignored in production.
# Non-production only (e.g. Docker): allow non-loopback peers if you must:
# EDITOR_MAP_RELOAD_ALLOW_NON_LOCAL=true
