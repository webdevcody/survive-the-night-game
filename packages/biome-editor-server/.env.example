# Must match packages/game-server (and website) GAME_SERVER_API_KEY for map reload after save.
GAME_SERVER_API_KEY=

# Game server HTTP base (WebSocket port; reload is POST /__dev/reload-world-map).
GAME_SERVER_BASE_URL=http://localhost:3001

# NOTIFY_GAME_SERVER_ON_MAP_SAVE=false

# Log every GET /api/world-map (noisy with React Query). Default: omit from logs.
# EDITOR_API_LOG_WORLD_MAP_GET=true
